#!/bin/sh /etc/rc.common

USE_PROCD=1
START=95
STOP=10

PROG=/usr/bin/ps2servers-edge

append_bool_flag() {
        local section="$1" option="$2" flag="$3" value
        config_get_bool value "$section" "$option" 0
        [ "$value" -eq 1 ] && procd_append_param command "$flag"
}

start_service() {
        config_load ps2servers-edge
        config_get_bool enabled main enabled 0
        [ "$enabled" -eq 1 ] || return 0

        config_get root main root /mnt/sda1/PS2
        config_get bind main bind 0.0.0.0
        config_get port main port 62966
        config_get data_port main data_port 0
        config_get protocol main protocol auto
        config_get peer_timeout main peer_timeout 1h
        config_get log_format main log_format text

        procd_open_instance
        procd_set_param command "$PROG" udpfs \
                --root "$root" \
                --bind "$bind" \
                --port "$port" \
                --data-port "$data_port" \
                --protocol-mode "$protocol" \
                --peer-timeout "$peer_timeout" \
                --log-format "$log_format" \
                --read-only
        append_bool_flag main single_port --single-port
        append_bool_flag main verbose --verbose
        procd_set_param user ps2edge
        procd_set_param group ps2edge
        procd_set_param respawn 10 5 0
        procd_set_param stdout 1
        procd_set_param stderr 1
        procd_set_param limits nofile="256 256"
        procd_close_instance
}

service_triggers() {
        procd_add_reload_trigger ps2servers-edge
}
